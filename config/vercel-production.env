# 🚀 VERCEL 정상 운영 환경변수 설정
# Google Cloud 마이그레이션 완료 후 안정적인 운영을 위한 설정

# === 1. 기본 시스템 설정 ===
NEXT_PUBLIC_EMERGENCY_MODE=false
EMERGENCY_THROTTLE=false
DISABLE_ALL_EDGE_RUNTIME=false
FORCE_NODE_RUNTIME=false

# === 2. API 및 스케줄러 정상 활성화 ===
UNIFIED_METRICS_DISABLED=false
KEEP_ALIVE_SCHEDULER_DISABLED=false
SERVER_DATA_SCHEDULER_DISABLED=false
BACKGROUND_SCHEDULERS_DISABLED=false
SYSTEM_STATUS_POLLING_DISABLED=false
HEALTH_CHECK_POLLING_DISABLED=false

# === 3. 클라이언트 기능 정상 활성화 ===
REACT_QUERY_DISABLED=false
AUTO_REFRESH_DISABLED=false
REACT_QUERY_REFETCH_INTERVAL=30000

# === 4. AI 및 MCP 기능 ===
AI_QUERY_DISABLED=false
GOOGLE_AI_DISABLED=false
AI_AGENT_DISABLED=false
MCP_DISABLED=false

# === 5. 데이터 생성 및 수집 ===
DATA_GENERATOR_DISABLED=false
METRICS_COLLECTION_DISABLED=false
MOCK_DATA_ONLY=false

# === 6. 🚀 Vercel 최적화 설정 ===
NEXT_PUBLIC_VERCEL_OPTIMIZATION=true
NEXT_PUBLIC_SMART_POLLING=true
NEXT_PUBLIC_USE_GCP_DIRECT=true
NEXT_PUBLIC_CACHE_AGGRESSIVE=true

# === 7. 폴링 간격 최적화 ===
NEXT_PUBLIC_SYSTEM_STATUS_INTERVAL=90000
NEXT_PUBLIC_REALTIME_SERVERS_INTERVAL=120000
NEXT_PUBLIC_SERVER_DATA_STORE_INTERVAL=180000

# === 8. 캐싱 최적화 ===
VERCEL_EDGE_CACHE_ENABLED=true
VERCEL_STATIC_CACHE_TTL=3600
VERCEL_API_CACHE_TTL=60

# === 9. 성능 최적화 ===
NEXT_PUBLIC_OPTIMIZE_IMAGES=true
NEXT_PUBLIC_COMPRESS_RESPONSES=true
NEXT_PUBLIC_MINIMIZE_REQUESTS=true

# === 10. 모니터링 및 알림 ===
NEXT_PUBLIC_USAGE_MONITORING=true
NEXT_PUBLIC_ALERT_THRESHOLD=80

# === 11. 로깅 및 분석 ===
LOG_LEVEL=info
CONSOLE_LOG_DISABLED=false
ANALYTICS_DISABLED=false

# === 12. GCP 통합 설정 ===
GCP_FUNCTIONS_BASE_URL=https://us-central1-openmanager-vibe-v5.cloudfunctions.net
MCP_SERVER_URL=http://104.154.205.25:10000

# === 13. 성능 최적화 ===
MAX_STATUS_REQUESTS_PER_MINUTE=120
API_RATE_LIMIT_ENABLED=true
CONCURRENT_REQUEST_LIMIT=50

# ⚡ 적용 방법:
# 1. Vercel 대시보드 → Settings → Environment Variables
# 2. 위 모든 변수를 Production 환경에 추가
# 3. 기존 비상 모드 환경변수들 제거
# 4. 재배포 (vercel --prod)

# 📊 예상 효과:
# - 모든 기능 정상 활성화
# - 실시간 모니터링 복원
# - AI 기능 정상 동작
# - 사용자 경험 개선
# - Google Cloud 안정성 활용 