{
  "name": "gcp-enterprise-metrics",
  "version": "1.0.0",
  "description": "GCP Enterprise Metrics Generator - Vercel Alternative",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "firebase-functions": "^6.0.1"
  },
  "scripts": {
    "start": "node index.js",
    "deploy": "gcloud functions deploy enterprise-metrics --runtime nodejs20 --trigger-http --allow-unauthenticated --timeout 540s --memory 1GB"
  },
  "keywords": [
    "enterprise-metrics",
    "gcp",
    "cloud-functions",
    "openmanager",
    "monitoring"
  ],
